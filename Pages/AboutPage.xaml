<?xml version="1.0" encoding="utf-8" ?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RemindMe.Pages.AboutPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="#0B2B14">

  <ScrollView>

    <VerticalStackLayout Padding="28,26,28,40"
                         Spacing="24">

      <VerticalStackLayout Spacing="6">

        <Label Text="About RemindMe"
               FontSize="38"
               FontAttributes="Bold"
               TextColor="White"/>

        <Label Text="Stay organized every day."
               FontSize="20"
               TextColor="#9DB59F"/>

      </VerticalStackLayout>

      <Label Text="← Back"
             FontSize="18"
             TextColor="#DCECCF">

        <Label.GestureRecognizers>
          <TapGestureRecognizer Tapped="OnBackTapped"/>
        </Label.GestureRecognizers>

      </Label>

      <Border BackgroundColor="#163D1D"
              Stroke="#2E7D32"
              StrokeThickness="1"
              Padding="24">

        <Border.StrokeShape>
          <RoundRectangle CornerRadius="26"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="18">

          <Label Text="Creator"
                 FontSize="30"
                 FontAttributes="Bold"
                 TextColor="White"/>

          <Label Text="Zeki Kenan Köseoğlu"
                 FontSize="22"
                 TextColor="White"/>

          <Label Text="Software Engineering Student"
                 FontSize="18"
                 TextColor="#9DB59F"/>

          <Label Text="SDU Sønderborg, Denmark"
                 FontSize="18"
                 TextColor="#9DB59F"/>

        </VerticalStackLayout>

      </Border>

      <Border BackgroundColor="#163D1D"
              Stroke="#2E7D32"
              StrokeThickness="1"
              Padding="24">

        <Border.StrokeShape>
          <RoundRectangle CornerRadius="26"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="18">

          <Label Text="About The App"
                 FontSize="30"
                 FontAttributes="Bold"
                 TextColor="White"/>

          <Label Text="RemindMe is a productivity and reminder application designed to help users stay organized with reminders, notifications, Pomodoro sessions and daily task management."
                 FontSize="18"
                 LineHeight="1.4"
                 TextColor="#DCECCF"/>

        </VerticalStackLayout>

      </Border>

      <Border BackgroundColor="#163D1D"
              Stroke="#2E7D32"
              StrokeThickness="1"
              Padding="24">

        <Border.StrokeShape>
          <RoundRectangle CornerRadius="26"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="16">

          <Label Text="Features"
                 FontSize="30"
                 FontAttributes="Bold"
                 TextColor="White"/>

          <Label Text="• Reminder scheduling"
                 FontSize="18"
                 TextColor="#DCECCF"/>

          <Label Text="• Notification support"
                 FontSize="18"
                 TextColor="#DCECCF"/>

          <Label Text="• Pomodoro timer"
                 FontSize="18"
                 TextColor="#DCECCF"/>

          <Label Text="• Pomodoro history"
                 FontSize="18"
                 TextColor="#DCECCF"/>

          <Label Text="• Reminder filters"
                 FontSize="18"
                 TextColor="#DCECCF"/>

          <Label Text="• Multi-selection actions"
                 FontSize="18"
                 TextColor="#DCECCF"/>

        </VerticalStackLayout>

      </Border>

      <Border BackgroundColor="#163D1D"
              Stroke="#2E7D32"
              StrokeThickness="1"
              Padding="24">

        <Border.StrokeShape>
          <RoundRectangle CornerRadius="26"/>
        </Border.StrokeShape>

        <VerticalStackLayout Spacing="18">

          <Label Text="Disclaimer"
                 FontSize="30"
                 FontAttributes="Bold"
                 TextColor="White"/>

          <Label Text="Notification delivery and reminder timing may vary depending on device battery optimization settings and operating system behavior."
                 FontSize="18"
                 LineHeight="1.4"
                 TextColor="#DCECCF"/>

          <Label Text="RemindMe is designed as a productivity companion application."
                 FontSize="18"
                 LineHeight="1.4"
                 TextColor="#DCECCF"/>

        </VerticalStackLayout>

      </Border>

    </VerticalStackLayout>

  </ScrollView>

</ContentPage>