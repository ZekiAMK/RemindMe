<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RemindMe.Pages.AddReminderPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B2B14">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Label x:Name="PageTitle"
                   Text="Add Reminder"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="10">
                <Label Text="Title" TextColor="White" FontSize="16" />
                <Border Stroke="#2E7D32" StrokeThickness="1" BackgroundColor="White" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Entry x:Name="TitleEntry"
                           Placeholder="Enter reminder title"
                           TextColor="Black"
                           BackgroundColor="Transparent" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10">
                <Label Text="Description" TextColor="White" FontSize="16" />
                <Border Stroke="#2E7D32" StrokeThickness="1" BackgroundColor="White" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <Entry x:Name="DescriptionEntry"
                           Placeholder="Enter description"
                           TextColor="Black"
                           BackgroundColor="Transparent" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding Source={x:Reference SetAlertSwitch}, Path=IsToggled}">
                <Label Text="Date" TextColor="White" FontSize="16" />
                <Border Stroke="#2E7D32" StrokeThickness="1" BackgroundColor="White" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <DatePicker x:Name="ReminderDatePicker"
                                TextColor="Black"
                                BackgroundColor="Transparent" />
                </Border>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="10" IsVisible="{Binding Source={x:Reference SetAlertSwitch}, Path=IsToggled}">
                <Label Text="Time" TextColor="White" FontSize="16" />
                <Border Stroke="#2E7D32" StrokeThickness="1" BackgroundColor="White" Padding="10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="10" />
                    </Border.StrokeShape>
                    <TimePicker x:Name="ReminderTimePicker"
                                TextColor="Black"
                                BackgroundColor="Transparent" />
                </Border>
            </VerticalStackLayout>

            <HorizontalStackLayout Spacing="20">
                <Label Text="Important"
                       TextColor="White"
                       FontSize="16"
                       VerticalOptions="Center" />
                <Switch x:Name="ImportantSwitch" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="20">
                <Label Text="Set alert"
                       TextColor="White"
                       FontSize="16"
                       VerticalOptions="Center" />
                <Switch x:Name="SetAlertSwitch" IsToggled="False" />
            </HorizontalStackLayout>

            <HorizontalStackLayout Spacing="20" HorizontalOptions="Center">
                <Button Text="Save"
                        Clicked="OnSaveClicked"
                        BackgroundColor="#2E7D32"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="24,12" />

                <Button x:Name="DeleteButton"
                        Text="Delete"
                        Clicked="OnDeleteClicked"
                        BackgroundColor="#B71C1C"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="24,12"
                        IsVisible="False" />

                <Button Text="Cancel"
                        Clicked="OnCancelClicked"
                        BackgroundColor="Gray"
                        TextColor="White"
                        CornerRadius="20"
                        Padding="24,12" />
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>