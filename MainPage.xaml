<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RemindMe.MainPage"
             x:Name="MainPageRoot"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B2B14">

        <Grid RowDefinitions="Auto,*"
                        RowSpacing="20"
                        Padding="20">

                <VerticalStackLayout Grid.Row="0"
                                Spacing="20">
                        <Label Text="RemindMe"
                                        FontSize="32"
                                        FontAttributes="Bold"
                               TextColor="White"
                                        HorizontalOptions="Center"/>

                        <Label Text="Your daily reminders"
                                        FontSize="16"
                               TextColor="#DCECCF"
                                        HorizontalOptions="Center"/>

                        <Button Text="+ Add Reminder"
                                        Clicked="OnAddReminderClicked"
                                BackgroundColor="#2E7D32"
                                        TextColor="White"
                                CornerRadius="26"
                                        WidthRequest="220"
                                        HeightRequest="52"
                                FontSize="16"
                                        HorizontalOptions="Center"/>

                        <ScrollView Orientation="Horizontal"
                                        HorizontalScrollBarVisibility="Never">
                                <HorizontalStackLayout Spacing="12">

                                        <Button Text="All"
                                                        Clicked="OnAllClicked"
                                                BackgroundColor="#214B27"
                                                        TextColor="White"
                                                CornerRadius="20"
                                                        Padding="18,10"
                                                        FontSize="14">
                                                <Button.Triggers>
                                                        <DataTrigger TargetType="Button"
                                                                        Binding="{Binding ActiveFilter}"
                                                                        Value="All">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#2E7D32"/>
                                                        </DataTrigger>
                                                </Button.Triggers>
                                        </Button>

                                        <Button Text="Today"
                                                        Clicked="OnTodayClicked"
                                                BackgroundColor="#214B27"
                                                        TextColor="White"
                                                CornerRadius="20"
                                                        Padding="18,10"
                                                        FontSize="14">
                                                <Button.Triggers>
                                                        <DataTrigger TargetType="Button"
                                                                        Binding="{Binding ActiveFilter}"
                                                                        Value="Today">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#2E7D32"/>
                                                        </DataTrigger>
                                                </Button.Triggers>
                                        </Button>

                                        <Button Text="Important"
                                                        Clicked="OnImportantClicked"
                                                BackgroundColor="#214B27"
                                                        TextColor="White"
                                                CornerRadius="20"
                                                        Padding="18,10"
                                                        FontSize="14">
                                                <Button.Triggers>
                                                        <DataTrigger TargetType="Button"
                                                                        Binding="{Binding ActiveFilter}"
                                                                        Value="Important">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#2E7D32"/>
                                                        </DataTrigger>
                                                </Button.Triggers>
                                        </Button>

                                        <Button Text="No Alert"
                                                        Clicked="OnNoAlertClicked"
                                                BackgroundColor="#214B27"
                                                        TextColor="White"
                                                CornerRadius="20"
                                                        Padding="18,10"
                                                        FontSize="14">
                                                <Button.Triggers>
                                                        <DataTrigger TargetType="Button"
                                                                        Binding="{Binding ActiveFilter}"
                                                                        Value="No Alert">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#2E7D32"/>
                                                        </DataTrigger>
                                                </Button.Triggers>
                                        </Button>

                                        <Button Text="Completed"
                                                        Clicked="OnCompletedClicked"
                                                BackgroundColor="#214B27"
                                                        TextColor="White"
                                                CornerRadius="20"
                                                        Padding="18,10"
                                                        FontSize="14">
                                                <Button.Triggers>
                                                        <DataTrigger TargetType="Button"
                                                                        Binding="{Binding ActiveFilter}"
                                                                        Value="Completed">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#2E7D32"/>
                                                        </DataTrigger>
                                                </Button.Triggers>
                                        </Button>

                                        <Button Text="Past"
                                                        Clicked="OnPastClicked"
                                                BackgroundColor="#214B27"
                                                        TextColor="White"
                                                CornerRadius="20"
                                                        Padding="18,10"
                                                        FontSize="14">
                                                <Button.Triggers>
                                                        <DataTrigger TargetType="Button"
                                                                        Binding="{Binding ActiveFilter}"
                                                                        Value="Past">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#2E7D32"/>
                                                        </DataTrigger>
                                                </Button.Triggers>
                                        </Button>

                                </HorizontalStackLayout>
                        </ScrollView>

                        <Border IsVisible="{Binding IsSelectionMode}"
                                BackgroundColor="#163D1D"
                                Stroke="#2E7D32"
                                StrokeThickness="1"
                                Padding="14"
                                Margin="0,-8,0,0">
                                <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="18"/>
                                </Border.StrokeShape>

                                <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                                                ColumnSpacing="10">
                                        <Label Text="{Binding SelectedCount, StringFormat='{}{0} selected'}"
                                               TextColor="White"
                                                        FontSize="15"
                                                        VerticalOptions="Center"/>

                                        <Button Grid.Column="1"
                                                Text="{Binding SelectionPrimaryActionText}"
                                                Clicked="OnCompleteSelectedClicked"
                                                BackgroundColor="{Binding SelectionPrimaryActionColor}"
                                                TextColor="White"
                                                CornerRadius="16"
                                                Padding="12,8"/>

                                        <Button Grid.Column="2"
                                                Text="Delete"
                                                Clicked="OnDeleteSelectedClicked"
                                                BackgroundColor="#B71C1C"
                                                TextColor="White"
                                                CornerRadius="16"
                                                Padding="12,8"/>

                                        <Button Grid.Column="3"
                                                Text="Cancel"
                                                Clicked="OnCancelSelectionClicked"
                                                BackgroundColor="Gray"
                                                TextColor="White"
                                                CornerRadius="16"
                                                Padding="12,8"/>
                                </Grid>
                        </Border>
                </VerticalStackLayout>

                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding Reminders}"
                                VerticalOptions="FillAndExpand"
                                SelectionMode="None">

                        <CollectionView.ItemTemplate>
                                <DataTemplate>
                                        <Border Margin="0,0,0,16"
                                                Padding="18"
                                                Stroke="#2E7D32"
                                                StrokeThickness="1"
                                                BackgroundColor="White">

                                                <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="20"/>
                                                </Border.StrokeShape>

                                                <Border.Triggers>
                                                        <DataTrigger TargetType="Border"
                                                                        Binding="{Binding IsSelected}"
                                                                        Value="True">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#DFF3E2"/>
                                                                <Setter Property="StrokeThickness"
                                                                                Value="3"/>
                                                        </DataTrigger>

                                                        <DataTrigger TargetType="Border"
                                                                        Binding="{Binding IsCompleted}"
                                                                        Value="True">
                                                                <Setter Property="BackgroundColor"
                                                                                Value="#ECECEC"/>
                                                                <Setter Property="Opacity"
                                                                                Value="0.9"/>
                                                        </DataTrigger>
                                                </Border.Triggers>

                                                <Grid ColumnDefinitions="*,Auto"
                                                                ColumnSpacing="16">

                                                        <VerticalStackLayout Grid.Column="0"
                                                                        Spacing="8">
                                                                <VerticalStackLayout.GestureRecognizers>
                                                                        <TapGestureRecognizer Tapped="OnReminderCardTapped"
                                                                                              CommandParameter="{Binding .}"/>
                                                                </VerticalStackLayout.GestureRecognizers>

                                                                <Label Text="{Binding Title}"
                                                                       FontSize="20"
                                                                       FontAttributes="Bold"
                                                                       TextColor="#0B2B14">
                                                                        <Label.Triggers>
                                                                                <DataTrigger TargetType="Label"
                                                                                                Binding="{Binding IsPastDue}"
                                                                                                Value="True">
                                                                                        <Setter Property="TextColor"
                                                                                                        Value="#C62828"/>
                                                                                </DataTrigger>

                                                                                <DataTrigger TargetType="Label"
                                                                                                Binding="{Binding IsCompleted}"
                                                                                                Value="True">
                                                                                        <Setter Property="TextDecorations"
                                                                                                        Value="Strikethrough"/>
                                                                                        <Setter Property="TextColor"
                                                                                                        Value="#6F6F6F"/>
                                                                                </DataTrigger>
                                                                        </Label.Triggers>
                                                                </Label>

                                                                <Label Text="{Binding Description}"
                                                                       FontSize="14"
                                                                       TextColor="#2E3F34">
                                                                        <Label.Triggers>
                                                                                <DataTrigger TargetType="Label"
                                                                                                Binding="{Binding IsPastDue}"
                                                                                                Value="True">
                                                                                        <Setter Property="TextColor"
                                                                                                        Value="#A94442"/>
                                                                                </DataTrigger>

                                                                                <DataTrigger TargetType="Label"
                                                                                                Binding="{Binding IsCompleted}"
                                                                                                Value="True">
                                                                                        <Setter Property="TextDecorations"
                                                                                                        Value="Strikethrough"/>
                                                                                        <Setter Property="TextColor"
                                                                                                        Value="#7A7A7A"/>
                                                                                </DataTrigger>
                                                                        </Label.Triggers>
                                                                </Label>

                                                                <Label Text="{Binding ReminderTime, StringFormat='{}{0:MMM d, h:mm tt}'}"
                                                                       FontSize="13"
                                                                       TextColor="#5F6E63">
                                                                        <Label.Triggers>
                                                                                <DataTrigger TargetType="Label"
                                                                                                Binding="{Binding IsPastDue}"
                                                                                                Value="True">
                                                                                        <Setter Property="TextColor"
                                                                                                        Value="#D32F2F"/>
                                                                                </DataTrigger>

                                                                                <DataTrigger TargetType="Label"
                                                                                                Binding="{Binding IsCompleted}"
                                                                                                Value="True">
                                                                                        <Setter Property="TextDecorations"
                                                                                                        Value="Strikethrough"/>
                                                                                        <Setter Property="TextColor"
                                                                                                        Value="#7A7A7A"/>
                                                                                </DataTrigger>
                                                                        </Label.Triggers>
                                                                </Label>
                                                        </VerticalStackLayout>

                                                        <VerticalStackLayout Grid.Column="1"
                                                                             Spacing="12"
                                                                             VerticalOptions="Center">

                                                                <Button Text="⋯"
                                                                        Clicked="OnSelectModeClicked"
                                                                        CommandParameter="{Binding .}"
                                                                        WidthRequest="34"
                                                                        HeightRequest="34"
                                                                        CornerRadius="17"
                                                                        BackgroundColor="Transparent"
                                                                        BorderColor="#2E7D32"
                                                                        BorderWidth="1"
                                                                        TextColor="#2E7D32"
                                                                        FontSize="18"/>

                                                                <Button WidthRequest="34"
                                                                        HeightRequest="34"
                                                                        CornerRadius="17"
                                                                        BackgroundColor="Transparent"
                                                                        BorderColor="#2E7D32"
                                                                        BorderWidth="1"
                                                                        TextColor="#2E7D32"
                                                                        FontAttributes="Bold"
                                                                        Clicked="OnCompleteTapped"
                                                                        CommandParameter="{Binding .}">

                                                                        <Button.Triggers>
                                                                                <DataTrigger TargetType="Button"
                                                                                                Binding="{Binding IsCompleted}"
                                                                                                Value="True">
                                                                                        <Setter Property="IsVisible"
                                                                                                        Value="False"/>
                                                                                </DataTrigger>
                                                                        </Button.Triggers>
                                                                </Button>

                                                        </VerticalStackLayout>
                                                </Grid>
                                        </Border>
                                </DataTemplate>
                        </CollectionView.ItemTemplate>
                </CollectionView>

        </Grid>
</ContentPage>